# 반디 퀀트 API 설정 파일
# 이 파일을 .env로 복사한 후 실제 키를 입력하세요
# .env 파일은 Git에 올라가지 않습니다 (.gitignore에 등록됨)

# === 텔레그램 (필수) ===
# 텔레그램 봇 토큰 (BotFather에서 발급)
export TELEGRAM_TOKEN="your_bot_token_here"

# 텔레그램 채팅방 ID (숫자만, 예: 6146433054)
export TELEGRAM_CHAT_ID="your_chat_id_here"

# === 네이버 클로바 TTS (브리핑 음성용) ===
# 네이버 클라우드 API 콘솔에서 발급
export NAVER_CLOVA_CLIENT_ID="your_client_id_here"
export NAVER_CLOVA_CLIENT_SECRET="your_client_secret_here"

# === Alpha Vantage (주가 데이터 - 선택) ===
# https://www.alphavantage.co/support/#api-key 에서 무료 발급
# export ALPHAVANTAGE_API_KEY="your_key_here"

# === OpenAI (향후 사용 - 선택) ===
# export OPENAI_API_KEY="your_key_here"

# === 경로 설정 (로컬용) ===
export WORKSPACE_DIR="/Users/yourname/workspace"
