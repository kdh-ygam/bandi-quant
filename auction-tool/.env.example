# 경매 분석 툴 - 환경 변수 설정
# 이 파일을 복사해서 .env 파일로 만들고 실제 값을 입력하세요

# OpenAI API 키 (필수)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=your_openai_api_key_here

# Telegram Bot 토큰 (선택)
# @BotFather 에서 발급
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram 챗 ID (선택)
TELEGRAM_CHAT_ID=6146433054
